Thumbs.db

# TypeScript build outputs (default-ignored). The framework's dist/ is
# explicitly negated below because consumers install from GitHub via
# `pnpm add github:user/repo#path:packages/framework` and expect compiled
# JS + .d.ts to ship in the package.
dist/
*.tsbuildinfo
!packages/framework/dist/
!packages/framework/dist/**

# Test fixtures that bootstrap their own .git dynamically
packages/cli/tests/fixtures/branched-repo/.git/
packages/cli/tests/fixtures/branched-repo/a.txt

