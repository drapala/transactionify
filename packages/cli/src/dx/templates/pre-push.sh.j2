#!/usr/bin/env bash
# Generated by `dx init`. Local-vs-CI parity: this hook runs the SAME work_id
# and lint commands `dx check` runs in CI. Unit tests are NOT in pre-push —
# they run in CI on push (deliberate scoping; see ADR §Pre-push).
set -euo pipefail

if ! command -v dx >/dev/null 2>&1; then
  echo "pre-push: dx CLI not on PATH. Run: uv tool install --editable packages/cli" >&2
  exit 1
fi

# work_id check first — fast, fails-fast on bad branch/commit names.
dx check work_id || {
  echo "pre-push: work_id check failed. Branch + commit subjects must match ^(LL|GP)-[0-9]+(-...|: ...)" >&2
  exit 1
}

# lint after — PDF p.4 §3.b literal phrase: "mandatory tests/linting before code is pushed".
dx check lint || {
  echo "pre-push: lint failed. Fix lint errors before pushing." >&2
  exit 1
}
