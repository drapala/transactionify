{
  "name": "@golden-path/framework",
  "version": "0.1.0",
  "private": true,
  "description": "Golden Path TypeScript framework — generates GitHub Actions workflows + CDK patterns. Consumes @golden-path/shared-schemas as source of truth.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "codegen": "tsx scripts/codegen-types.ts",
    "gen-fixtures": "tsx scripts/gen-fixtures.ts",
    "gen-workflows": "tsx scripts/gen-fixtures.ts"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@golden-path/shared-schemas": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "json-schema-to-typescript": "^15.0.3",
    "tsx": "^4.19.2",
    "typescript": "~5.3.0",
    "vitest": "^2.1.4"
  }
}
